"""
Nova Memory Slot Retrieval
==========================
Retrieves memory by slot name, keyword, or user intent.
Bridges the old lesson-based memory with the new long-term memory.

Flow:
  1. Query long-term memory by slot or keywords
  2. Fallback to lesson-based memory search
  3. Return structured results with synthesis support
"""

import json, os, sys, re
from datetime import datetime

ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
sys.path.insert(0, os.path.join(ROOT, "src"))


def retrieve(plan, legacy_memory=None, raw_user_message=None):
    """
    Retrieve memory based on the validated plan.

    Args:
        plan: validated plan dict with route, slot_needed, etc.
        legacy_memory: optional old-style memory dict with 'lessons' key.
        raw_user_message: original user message for fallback search.

    Returns:
        dict with:
          - found: bool
          - records: list of matching records
          - slot_used: str
          - source: "long_term" | "lesson" | "none"
          - synthesized_answer: str or None
          - raw_text: str or None
    """
    result = {
        "found": False,
        "records": [],
        "slot_used": None,
        "source": "none",
        "synthesized_answer": None,
        "raw_text": None,
    }

    if not plan:
        return result

    route = plan.get("route", "")
    slot_needed = plan.get("slot_needed")
    slot = slot_needed if slot_needed and slot_needed not in (None, "null") else None

    # ─── Phase 1: Long-Term Memory by slot ───
    if slot:
        try:
            from nova_long_term_memory import find_by_slot, get_all
            slot_records = find_by_slot(slot)
            if slot_records:
                best = slot_records[0]
                result["found"] = True
                result["records"] = slot_records
                result["slot_used"] = slot
                result["source"] = "long_term"
                result["raw_text"] = best.get("raw_text", "")
                return result
        except Exception:
            pass

    # ─── Phase 2: Long-Term Memory by keyword match ───
    if raw_user_message:
        try:
            from nova_long_term_memory import find_by_keyword
            q = raw_user_message.lower().strip()
            keywords = [w for w in q.split() if len(w) > 2]
            if keywords:
                kw_records = find_by_keyword(keywords)
                if kw_records:
                    best = kw_records[0]
                    result["found"] = True
                    result["records"] = kw_records
                    result["slot_used"] = best.get("extracted_slot")
                    result["source"] = "long_term"
                    result["raw_text"] = best.get("raw_text", "")
                    return result
        except Exception:
            pass

    # ─── Phase 3: Legacy lesson-based memory ───
    if legacy_memory and raw_user_message:
        try:
            from nova_hybrid_router import _search_lessons
            lessons_found = _search_lessons(raw_user_message, legacy_memory)
            if lessons_found:
                best_text = lessons_found[0]
                result["found"] = True
                result["records"] = [{"raw_text": t} for t in lessons_found]
                result["source"] = "lesson"
                result["raw_text"] = best_text

                # Try to synthesize answer
                try:
                    from nova_hybrid_router import _synthesize_answer
                    syn = _synthesize_answer(best_text, raw_user_message)
                    if syn:
                        result["synthesized_answer"] = syn
                except Exception:
                    pass

                return result
        except Exception:
            pass

    return result


def retrieve_profile_slot(slot_name, user_message=None):
    """
    Convenience function: retrieve a single slot value from long-term memory.

    Args:
        slot_name: e.g., "favorite_food", "name", "location"
        user_message: optional user message for fallback

    Returns:
        (value, raw_text) or (None, None)
    """
    try:
        from nova_long_term_memory import find_by_slot
        records = find_by_slot(slot_name)
        if records:
            r = records[0]
            return r.get("extracted_value"), r.get("raw_text")
    except Exception:
        pass
    return None, None


def get_all_slot_summary():
    """Get a summary of all saved slots for display."""
    try:
        from nova_long_term_memory import get_all
        records = get_all(active_only=True)
        slots = {}
        for r in records:
            s = r.get("extracted_slot", "unknown")
            v = r.get("extracted_value", "")
            slots[s] = v
        return slots
    except Exception:
        return {}
